@article{grohlich_wirkt_2009,
	title = {Wirkt sich Leistungsheterogenität in Schulklassen auf den individuellen Lernerfolg in der Sekundarstufe aus?},
	volume = {1},
	rights = {Deutsches Urheberrecht},
	issn = {1866-6671},
	url = {https://www.pedocs.de/frontdoor.php?source_opus=4557},
	doi = {10.25656/01:4557},
	abstract = {How to best accommodate the variety of preconditions that students bring to their learning is a frequently asked question. The study documented in this article sought to further illuminate answers to this question by focusing on whether the conditions for learning and for students’ achievement are better and higher in homogeneous or heterogeneous ability groups. Data from the longitudinal study {KESS} (Competencies and Attitudes of Students) were used to analyze the relationship between heterogeneity at class level (N = 514) and student achievement (N = 10 036). Tracked classes were found to be more homogeneous than classes in comprehensive schools in terms of reading achievement. In relation to mathematics achievement, however, the highest track (Gymnasium) included the most heterogeneous classes. Multilevel analyses showed that achievement heterogeneity in classes had neither positive nor negative effects on individual learning.},
	pages = {86--105},
	number = {1},
	journaltitle = {Journal for educational research online},
	author = {Gröhlich, Carola and Scharenberg, Katja and Bos, Wilfried},
	editora = {{DIPF {\textbar} Leibniz-Institut für Bildungsforschung und Bildungsinformation}},
	editoratype = {collaborator},
	urldate = {2024-07-22},
	date = {2009},
	langid = {german},
	note = {Publisher: Waxmann : Münster},
	keywords = {370 Education, 370 Erziehung, Schul- und Bildungswesen, Achievement measurement, Achievement test, Comprehensive school, Comprehensive secondary school, Deutschland, Deutschunterricht, Empirical study, Empirische Untersuchung, German academic secondary school, German language teaching, German non-academic secondary school, Germany, Gesamtschule, Grammar School, Gymnasium, Hamburg, Hauptschule, Heterogeneity, Heterogenität, Intermediate school, Learning achievement, Leistungsbeurteilung, Lernerfolg, Lerngruppe, Leseverstehen, Lower level secondary education, Lower secondary, Lower secondary education, Mathematics lessons, Mathematikunterricht, Pupil, Pupil achievement, Pupil Evaluation, Pupils, Reading comprehension, Realschule, School class, School year 05, School year 06, Schüler, Schülerleistung, Schulform, Schuljahr 05, Schuljahr 06, Schulklasse, Secondary education lower level, Secondary school, Sekundarstufe I, Student achievement, Study group, Teaching of German, Teaching of mathematics, Type of school, Wirkung},
	file = {Gröhlich et al. - 2009 - Wirkt sich Leistungsheterogenität in Schulklassen .pdf:/Users/lukas/Zotero/storage/PLVSCJ3Q/Gröhlich et al. - 2009 - Wirkt sich Leistungsheterogenität in Schulklassen .pdf:application/pdf},
}

