@book{walker_text_2024,
	title = {Text Classification in Detection of {AI}-Generated Content Using {BERT}},
	doi = {10.13140/RG.2.2.30193.90722},
	abstract = {Recent advancements in artificial intelligence have raised concerns about the authenticity of text, prompting the need for effective detection methods for {AI}-generated content. In this study, we introduce a novel approach that utilizes Bidirectional Encoder Representations from Transformers ({BERT}) for text classification. By fine-tuning the {BERT} model on a carefully curated dataset comprising both human-written and {AI}-generated texts, we facilitate the model's ability to discern between the two categories. The use of transfer learning significantly enhances performance, allowing for efficient classification even with limited labeled data. Our evaluation highlights the model's robustness and accuracy across various benchmark datasets, confirming its capability to identify {AI}-generated content in diverse domains. Furthermore, we delve into the significance of different features generated by {BERT} and their role in classification outcomes. The findings reveal the method's high precision and recall rates, coupled with its adaptability to the evolving landscape of {AI} text generation, establishing its usefulness as a tool for content verification. Comparisons with conventional machine learning approaches demonstrate the superior effectiveness of our {BERT}-based system in addressing this critical issue. {ABSTRACT} Recent advancements in artificial intelligence have raised concerns about the authenticity of text, prompting the need for effective detection methods for {AI}-generated content. In this study, we introduce a novel approach that utilizes Bidi-rectional Encoder Representations from Transformers ({BERT}) for text classification. By fine-tuning the {BERT} model on a carefully curated dataset comprising both human-written and {AI}-generated texts, we facilitate the model's ability to discern between the two categories. The use of transfer learning significantly enhances performance , allowing for efficient classification even with limited labeled data. Our evaluation highlights the model's robustness and accuracy across various benchmark datasets, confirming its capability to identify {AI}-generated content in diverse domains. Furthermore, we delve into the significance of different features generated by {BERT} and their role in classification outcomes. The findings reveal the method's high precision and recall rates, coupled with its adaptability to the evolv-* Equal contribution},
	author = {Walker, Ethan and Evans, Lucas and Mitchell, Ava and Zhang, Zoe and Patel, Ryan and Chen, Isabella},
	date = {2024-10-19},
	file = {Full Text PDF:/Users/lukas/Zotero/storage/KRYRIIHE/Walker et al. - 2024 - Text Classification in Detection of AI-Generated Content Using BERT.pdf:application/pdf},
}

@article{chaka_detecting_2023,
	title = {Detecting {AI} content in responses generated by {ChatGPT}, {YouChat}, and Chatsonic: The case of five {AI} content detection tools},
	volume = {6},
	doi = {10.37074/jalt.2023.6.2.12},
	shorttitle = {Detecting {AI} content in responses generated by {ChatGPT}, {YouChat}, and Chatsonic},
	abstract = {This paper set out to test the accuracy of five {AI} content tools, {GPTZero}, {OpenAI} Text Classifier, Writer.com’s {AI} Content Detector, Copyleaks {AI} Content Detector, and Giant Language model Test Room, to detect {AI}-generated content in the responses generated by {ChatGPT}, {YouChat}, and Chatsonic. The responses were generated from these three {AI} chatbots using English prompts related to applied English language studies. Then, the {ChatGPT}-generated responses were Google-translated into German, French, Spanish, Southern Sotho, and {isiZulu}, and inputted into {GPTZero} for it to detect the {AI}-generated content in them. Additionally, the {ChatGPT}-generated responses Google-translated into German, French and Spanish were inputted into Copyleaks {AI} Content Detector for it to detect the {AI}-generated content in them. For the {ChatGPT}-, {YouChat}-, and Chatsonic-generated responses, Copyleaks {AI} Content Detector emerged as the top-most performing {AI} content detector among the five {AI} content detectors. It was followed by {OpenAI}’s {AI} Text Classifier. Concerning the {ChatGPT}-generated responses that were Google-translated into five languages, {GPTZero} misidentified all of them as human-produced. For the {ChatGPT}-generated responses that were Google-translated into German, French and Spanish, Copyleaks {AI} Content Detector correctly identified three of the German-translated texts, five of the French-translated texts, and all the Spanish-translated texts as {AI}-generated. Thus, it is evident from this paper that all five {AI} content detectors seem not yet fully ready to accurately and convincingly detect {AI}-generated content from machine-generated texts in different contexts. This has dire consequences for {AI}-generated plagiarism in academic essay writing.},
	pages = {1--11},
	journaltitle = {Journal of Applied Learning \& Teaching},
	shortjournal = {Journal of Applied Learning \& Teaching},
	author = {Chaka, Chaka},
	date = {2023-07-24},
	file = {Full Text PDF:/Users/lukas/Zotero/storage/U4B6J2BH/Chaka - 2023 - Detecting AI content in responses generated by ChatGPT, YouChat, and Chatsonic The case of five AI.pdf:application/pdf},
}

@article{fleckenstein_teachers_2024,
	title = {Do teachers spot {AI}? Evaluating the detectability of {AI}-generated texts among student essays},
	volume = {6},
	issn = {2666-920X},
	url = {https://www.sciencedirect.com/science/article/pii/S2666920X24000109},
	doi = {10.1016/j.caeai.2024.100209},
	shorttitle = {Do teachers spot {AI}?},
	abstract = {The potential application of generative artificial intelligence ({AI}) in schools and universities poses great challenges, especially for the assessment of students’ texts. Previous research has shown that people generally have difficulty distinguishing {AI}-generated from human-written texts; however, the ability of teachers to identify an {AI}-generated text among student essays has not yet been investigated. Here we show in two experimental studies that novice (N = 89) and experienced teachers (N = 200) could not identify texts generated by {ChatGPT} among student-written texts. However, there are some indications that more experienced teachers made more differentiated and more accurate judgments. Furthermore, both groups were overconfident in their judgments. Effects of real and assumed source on quality assessment were heterogeneous. Our findings demonstrate that with relatively little prompting, current {AI} can generate texts that are not detectable for teachers, which poses a challenge to schools and universities in grading student essays. Our study provides empirical evidence for the current debate regarding exam strategies in schools and universities in light of the latest technological developments.},
	pages = {100209},
	journaltitle = {Computers and Education: Artificial Intelligence},
	shortjournal = {Computers and Education: Artificial Intelligence},
	author = {Fleckenstein, Johanna and Meyer, Jennifer and Jansen, Thorben and Keller, Stefan D. and Köller, Olaf and Möller, Jens},
	urldate = {2025-11-09},
	date = {2024-06-01},
	keywords = {{ChatGPT}, Essay writing, Generative {AI}, Teachers, Writing assessment},
	file = {ScienceDirect Snapshot:/Users/lukas/Zotero/storage/XJYG7MP3/S2666920X24000109.html:text/html},
}

@article{orhani_risks_2025,
	title = {The Risks and Potential of {AI} in Education},
	volume = {2},
	doi = {10.55677/CRAJ/08-2025-Vol02I07},
	abstract = {Artificial intelligence ({AI}) is revolutionizing the delivery and perception of education in the modern era. This study
delves into the potential and risks associated with integrating {AI} into education, focusing on its advantages in customizing learning,
enhancing educational quality, and broadening global access. {AI}'s adaptive systems allow for personalized learning plans tailored
to individual student needs, leading to improved academic outcomes. Furthermore, {AI} streamlines administrative processes and
increases educational opportunities for underserved and resource-constrained communities. Despite these benefits, integrating {AI}
into education poses significant challenges, such as privacy issues, access disparities, and reliance on technology. Concerns about
student data privacy breaches and the lack of {AI} literacy among educators raise ethical questions about {AI} governance. Additionally,
variations in technological capabilities among countries and institutions exacerbate existing educational inequalities. The use of this
methodology is justified by the complexity of the topic and the diversity of the literature covering it. The main goal is to create a
clear understanding of the impact of {AI} in education, based on reliable scientific sources. This study highlights the importance of
adopting balanced approaches and responsible policies to ensure the ethical and effective integration of {AI} in education. Prioritizing
staff training, infrastructure development, and privacy safeguards is essential for mitigating risks associated with {AI}. Ultimately, {AI}
offers unprecedented possibilities for reshaping global education, provided that challenges are addressed thoughtfully with ethical
and regulatory considerations.},
	pages = {448--459},
	journaltitle = {Contemporary Research Analysis Journal},
	shortjournal = {Contemporary Research Analysis Journal},
	author = {Orhani, Senad and Hoti Kolukaj, Mimoza},
	date = {2025-07-31},
	file = {Full Text PDF:/Users/lukas/Zotero/storage/XF2HVUSP/Orhani and Hoti Kolukaj - 2025 - The Risks and Potential of AI in Education.pdf:application/pdf},
}

@book{deriba_fairness_2025,
	title = {Fairness and Inclusivity in {AI} Education: A Scoping Review of Socio-Pedagogical Challenges},
	shorttitle = {Fairness and Inclusivity in {AI} Education},
	abstract = {There is an imbalance in {AI} education research, with the majority of studies focusing on technical dimensions rather than the socio-pedagogical aspects of its implementation. This study aims to synthesize literature on {AI} education in inclusiveness, as well as the non-technical barriers that impact the participation of underrepresented and marginalized groups. Conducting a scoping review, we systematically searched the Scopus database and included 20 studies based on inclusion criteria. Our findings reveal that while many studies focus on developing {AI} literacy and critical skills, as well as enhancing equity and accessibility, research on the practical application and impact of {AI} in diverse communities remains notably scarce. The study identified four key socio-pedagogical challenges, with pedagogical challenges being the most cited at 60\% of the reviewed studies. Additionally, the lack of culturally relevant curricula, and psychological barriers such as low academic self-efficacy are highlighted. These findings underscore the need for research to develop contextually relevant curricula and for teacher training initiatives, particularly in underserved regions. A multifaceted strategy is required to address the underlying inequalities that hinder full participation in {AI} education, complementing technical advancements with a focus on socio-pedagogical considerations. 1 Introduction Artificial intelligence ({AI}) is becoming a foundational technology in 21st-century education, providing several opportunities to enhance learning outcomes and promote equity [1]. {AI}-powered tools like personalized learning platforms, intelligent tutors, and automated administrative systems promise to create efficient and responsive educational ecosystems [2]. As {AI} becomes integral to educational curricula, developing {AI} literacy is no longer a niche skill but a fundamental competency for all students and educators to effectively and critically engage with these adaptive technologies [3]. The rapid integration of {AI} into education carries challenges, particularly in existing social and educational inequalities. While the goal of {AI} education is to empower all individuals as users or creators in an {AI}-driven world, the benefits are not being used equally. There is a growing concern that without a focus on fairness and inclusivity, certain groups were left behind [4]. Therefore, a critical examination of {AI} in education is required beyond technical implementation to address its socio-pedagogical dimensions [5]. Fairness and inclusivity, from a socio-pedagogical perspective, are the cornerstones of equitable {AI} education. Fairness extends beyond technical concerns of algorithmic bias to address equitable access and opportunity to different educational stakeholders [6]. It seeks to overcome the socioeconomic, and cultural barriers-such as the high cost of technology, disparities in internet connectivity, and a lack of qualified {AI} educators-that prevent full participation in {AI} education, particularly in under-resourced communities [7]. Inclusivity complements fairness by focusing on curriculum and pedagogy [8]. {AI} education should be designed to be welcoming and accessible to all learners, ensuring that teaching methods and learning materials should be culturally relevant and adaptable to diverse student experiences and backgrounds [9]. Furthermore, there is a need for culturally relevant curricula and contextualizing learning in {AI} education [10]. However, while examining to fulfil these needs or develop culturally relevant {AI} curricula, different studies have identified several challenges, such as biases within current {AI} models. For example, researchers argue that {AI} models were trained on data from Western, Educated, Industrialized, Rich, and Democratic societies [11], leading to an exclusion of underrepresented or disadvantaged communities. To address these issues, limited studies examined pedagogical design and co-creation, empowering local communities to build their own {AI} solutions using culturally specific datasets [12], as well as emphasized integration of critical {AI} literacy into curricula [13], and the support of localized {AI} that is contextually aware and aligned with community values [14], thereby promoting technological sovereignty over dependency. However, the majority of existing studies, including reviews, were focused on the technical dimensions of {AI}, such as algorithmic bias, data privacy, and model fairness metrics [15]. While this area is vital, it often overlooks the human-centered aspects of socio-pedagogical {AI} implementation particularly in developing regions. For example, many curriculum development initiatives are focused in developed regions like North America and Europe, leaving a gap in understanding how to create culturally and linguistically inclusive {AI} education either for developing regions or Global South audience [16]. Furthermore, there is a lack of teacher training on {AI} education, or tools. The perspectives, pedagogical needs, and lived experiences of marginalized communities on {AI} education remain under-researched. This scoping review seeks to examine the current state of focus in inclusivity of {AI} education and challenges in underrepresented communities by synthesizing literature. Our study focuses specifically on the non-technical, socio-pedagogical aspects of fairness and inclusivity in {AI} education. To guide this review, two research questions are proposed: ({RQ}1) : What are the primary areas of focus in studies addressing equitable and inclusive {AI} education? and ({RQ}2): What are the social and educational challenges limiting fair access to {AI} education for underrepresented communities? 2 Methodology 3.1. Review protocol and Rationale This study employed a scoping review methodology, guided by the five-stage framework established by Arksey and O'Malley [17]. The approach was selected due to its suitability in mapping the extent, and identifying key concepts. Consequently, the study was designed to synthesize existing studies on fairness and inclusivity within {AIEd} from a socio-pedagogical perspective. In accordance with the review protocol, the initial stage involved two key steps: (1) the formulation of specific research questions to define the scope of the study, and (2) the identification of relevant academic databases for the literature search. 3.2. Search Strategy and Study Section The second stage of the review involved a systematic search for relevant studies, followed by a multi-phase screening and selection process. A search was conducted in the Scopus database, targeting the title, abstract, and keywords of publications. The search string combined two sets of aspects: one focused on {AIEd} concepts and another on fairness and inclusivity. Specifically we used search term: ("{AI} The initial search yielded 295 articles. These articles then underwent an initial screening based on the inclusion and exclusion criteria as detailed in Table 1, which led to removal of 63 articles for reasons such as being a review or a non-standard publication type (e.g., Note, Editorial) and leaving 233 studies for further assessment. Subsequently, the titles and abstracts of these articles were screened using the Rayyan tool, where an additional 195 studies were excluded for not meeting the inclusion criteria. This screening phase resulted in 38 articles being retained for full-text analysis. Finally, a full-text review of these articles was conducted to determine their relevance to answer the {RQs}. From 38 studies 22 were excluded (e.g. studies differently-abled, special need education), and resulted in a final corpus of 16 studies. Furthermore, based on the included studies, we conducted forward and backward snowballing [18] and obtained 4 additional studies. Finally, 20 studies were included for data extraction and synthesis.},
	author = {Deriba, Fitsum and Saqr, Mohammed},
	date = {2025-10-17},
	file = {Full Text PDF:/Users/lukas/Zotero/storage/G96YIJEZ/Deriba and Saqr - 2025 - Fairness and Inclusivity in AI Education A Scoping Review of Socio-Pedagogical Challenges.pdf:application/pdf},
}

@article{farahani_artificial_2024,
	title = {Artificial Intelligence in education: A comprehensive study},
	volume = {2},
	doi = {10.59400/fes.v2i3.1379},
	shorttitle = {Artificial Intelligence in education},
	abstract = {This comprehensive study delves into the multifaceted role of {AI} in education, exploring its applications, benefits, challenges, and future implications. The purpose of the study is to show how {AI} n education helps educators identify gaps in student knowledge and provide targeted feedback to improve learning outcomes. As a methodology, the library method and the study and review of various documents have been used in this research. The study examines the diverse range of {AI} technologies employed in educational settings, including intelligent tutoring systems, personalized learning platforms, educational chatbots, and virtual reality simulations. Furthermore, the study delves into the numerous benefits that {AI} brings to education. It highlights how {AI}-powered analytics and data-driven insights enable educators to gain deeper insights into student learning patterns, identify areas for improvement, and tailor instructional strategies accordingly. Additionally, {AI}-driven tools promote inclusivity by providing personalized support to learners with diverse needs and learning styles. Despite its transformative potential, the study also acknowledges the challenges and ethical considerations associated with integrating {AI} into education. Data privacy, algorithmic bias, and the digital divide are examined in detail, emphasizing the importance of responsible {AI} deployment and ethical guidelines. Looking ahead, the study explores the future implications of {AI} in education and the evolving role of educators in {AI}-enabled classrooms. It discusses how {AI} technologies will continue to evolve, offering new opportunities for collaborative learning, skill development, and lifelong education. In conclusion, this comprehensive study underscores the profound impact of {AI} on education and the need for thoughtful implementation strategies that prioritize equity, inclusivity, and ethical considerations. By harnessing the potential of {AI}, education systems can better prepare learners for the challenges and opportunities of the future.},
	journaltitle = {Forum for Education Studies},
	shortjournal = {Forum for Education Studies},
	author = {Farahani, Milad and Ghasemi, Ghazal},
	date = {2024-06-22},
	file = {Full Text PDF:/Users/lukas/Zotero/storage/E5CVBVUB/Farahani and Ghasemi - 2024 - Artificial Intelligence in education A comprehensive study.pdf:application/pdf},
}

@book{rahimi_ai_2025,
	title = {{AI} in Computational Thinking Education in Higher Education: A Systematic Literature Review},
	doi = {10.48550/arXiv.2510.09677},
	shorttitle = {{AI} in Computational Thinking Education in Higher Education},
	abstract = {Computational Thinking ({CT}) is a key skill set for students in higher education to thrive and adapt to an increasingly technology-driven future and workplace. While research on {CT} education has gained remarkable momentum in K12 over the past decade, it has remained under-explored in higher education, leaving higher education teachers with an insufficient overview, knowledge, and support regarding {CT} education. The proliferation and adoption of artificial intelligence ({AI}) by educational institutions have demonstrated promising potential to support instructional activities across many disciplines, including {CT} education. However, a comprehensive overview outlining the various aspects of integrating {AI} in {CT} education in higher education is lacking. To mitigate this gap, we conducted this systematic literature review study. The focus of our study is to identify initiatives applying {AI} in {CT} education within higher education and to explore various educational aspects of these initiatives, including the benefits and challenges of {AI} in {CT} education, instructional strategies employed, {CT} components covered, and {AI} techniques and models utilized. This study provides practical and scientific contributions to the {CT} education community, including an inventory of {AI}-based initiatives for {CT} education useful to educators, an overview of various aspects of integrating {AI} into {CT} education such as its benefits and challenges (e.g., {AI} potential to reshape {CT} education versus its potential to diminish students creativity) and insights into new and expanded perspectives on {CT} in light of {AI} (e.g., the decoding approach alongside the coding approach to {CT}).},
	author = {Rahimi, Ebrahim and Maathuis, Clara},
	date = {2025-10-08},
	file = {Full Text PDF:/Users/lukas/Zotero/storage/ZYG34AF5/Rahimi and Maathuis - 2025 - AI in Computational Thinking Education in Higher Education A Systematic Literature Review.pdf:application/pdf},
}

@article{kumar_ai_2025,
	title = {{AI} and Inclusive Education: Opportunities and Challenges},
	volume = {4},
	doi = {10.59828/ijsrmst.v4i9.375},
	shorttitle = {{AI} and Inclusive Education},
	abstract = {Artificial intelligence ({AI}), seen as a technology with the ability to perform complex tasks similar to the human brain, is emerging as a transformative tool in the field of education. It has opened new doors for learning and is making digital learning more comprehensive and excellent. {AI} is seen as having the potential to make learning more accessible and effective and to make it more inclusive by overcoming various learning barriers. Inclusive education, which provides equal educational opportunities to students regardless of their socio-economic status, language abilities, or disabilities, can be made more effective and widespread through {AI}. In inclusive education, {AI} helps make education more student-centric, removes various learning barriers such as language barriers, and provides adequate support to meet the needs of students with disabilities. This ensures that all students can receive a quality education. However, while {AI} is significantly impacting inclusive education, some challenges remain, such as students' insufficient access to digital facilities, a lack of basic infrastructure, inadequate teacher training, and concerns related to ethics and privacy. This research paper examines the role and opportunities of {AI} in education to make it more inclusive. It also identifies and investigates the challenges facing {AI} in inclusive education. Keywords: Artificial Intelligence, Inclusive Education, Children with disability, Personalized Learning, Linguistic Diversity, Assistive Technology},
	pages = {92--100},
	journaltitle = {International Journal of Scientific Research in Modern Science and Technology},
	shortjournal = {International Journal of Scientific Research in Modern Science and Technology},
	author = {Kumar, Sugandh},
	date = {2025-09-30},
	file = {Full Text PDF:/Users/lukas/Zotero/storage/QIXMUZXX/Kumar - 2025 - AI and Inclusive Education Opportunities and Challenges.pdf:application/pdf},
}

